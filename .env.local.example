# Copie ce fichier vers .env.local et remplace les valeurs.
# .env.local ne doit JAMAIS être partagé ou commité (déjà exclu via .gitignore).

# Mot de passe pour accéder à /admin.
# OBLIGATOIRE : remplace "change-moi" par un vrai mot de passe, sinon la
# connexion admin refusera de fonctionner (protection volontaire contre
# un déploiement avec les identifiants par défaut).
ADMIN_PASSWORD=change-moi

# Chaîne aléatoire utilisée pour signer les sessions admin.
# OBLIGATOIRE : minimum 32 caractères, sinon le serveur refuse de démarrer
# l'authentification. Génère-en une avec la commande :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=remplace-moi-par-une-longue-chaine-aleatoire-dau-moins-32-caracteres

# Optionnel — utilisé seulement en production (ex: Railway) pour pointer
# la base SQLite vers un disque persistant. En local, ne rien mettre :
# la base reste dans data/resultats.db par défaut.
# DATABASE_PATH=/app/storage/resultats.db

